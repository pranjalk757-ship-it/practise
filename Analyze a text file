def analyze_file(filename):
    # Open file in read mode
    with open(filename, 'r') as file:
        lines = file.readlines()   # Read all lines into a list

    total_lines = len(lines)  # Total number of lines

    # Count blank lines (lines with only spaces or empty)
    blank_lines = sum(1 for line in lines if line.strip() == "")

    # Count words (split each line into words)
    total_words = sum(len(line.split()) for line in lines)

    # Count characters (remove spaces and newline characters)
    total_chars = sum(len(line.replace(" ", "").replace("\n", "")) for line in lines)

    # Print results
    print("Lines:", total_lines)
    print("Blank Lines:", blank_lines)
    print("Words:", total_words)
    print("Characters:", total_chars)

# Function call
analyze_file("input.txt")
